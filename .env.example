# Nova environment template
# Copy to `.env` and adjust. All variables are optional; sensible local defaults apply.

# ---- Backend (Spring Boot) ----
# Full JDBC URL for any reachable PostgreSQL instance (Neon, Supabase, local, etc.).
# Docker is NOT required.
DATABASE_URL=jdbc:postgresql://localhost:5432/nova?sslmode=require
DB_USERNAME=nova
DB_PASSWORD=nova

# Active Spring profile: local | dev | prod
SPRING_PROFILES_ACTIVE=local

# CORS: comma-separated list of allowed frontend origins
NOVA_CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---- Frontend (Vite) ----
# Base URL of the Nova backend API.
VITE_API_BASE_URL=http://localhost:8080
