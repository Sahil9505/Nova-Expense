# Nova environment template
# Copy to `.env` and adjust. All variables are optional; sensible local defaults apply.

# ---- Backend (Spring Boot) ----
# Full JDBC URL for any reachable PostgreSQL instance (Neon, Supabase, local, etc.).
# Docker is NOT required.
DATABASE_URL=jdbc:postgresql://localhost:5432/nova?sslmode=require
DB_USERNAME=nova
DB_PASSWORD=nova

# Active Spring profile: local | dev | prod
SPRING_PROFILES_ACTIVE=local

# CORS: comma-separated list of allowed frontend origins
NOVA_CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---- JWT / Auth (safe local examples only — never commit real secrets) ----
# Signing secret for access + refresh tokens (HS256). MUST be overridden in shared/production.
JWT_SECRET=nova-local-development-secret-do-not-use-in-production-0123456789
# Access token lifetime in minutes (short-lived).
JWT_ACCESS_TOKEN_MINUTES=15
# Refresh token lifetime in days (long-lived, stored hashed).
JWT_REFRESH_TOKEN_DAYS=30

# ---- Frontend (Vite) ----
# Base URL of the Nova backend API.
VITE_API_BASE_URL=http://localhost:8080
 
# ---- AI Copilot (OpenRouter) ----
# Optional. The AI Copilot still boots and answers "not configured" when this is blank.
# Get a key at https://openrouter.ai/keys (the default model deepseek/deepseek-chat-v3-0324:free is free).
# Paste your key after the = sign, then tell me so I can run the live end-to-end test.
OPENROUTER_API_KEY=
# Optional model override (defaults to deepseek/deepseek-chat-v3-0324:free).
# OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free